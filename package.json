{
  "name": "@winds-ai/pi-native-codex-web-search",
  "version": "1.0.5",
  "description": "Native web search for Pi using OpenAI's Responses API via Codex backend (same as Codex CLI)",
  "type": "module",
  "main": "./src/index.ts",
  "files": [
    "src/index.ts",
    "src/auth.ts",
    "src/constants.ts",
    "src/search.ts",
    "src/types.ts",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "web-search",
    "codex",
    "openai",
    "search",
    "browser"
  ],
  "license": "CC0-1.0",
  "engines": {
    "node": ">=22"
  }
}
